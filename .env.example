# OpenRouter (OpenAI-compatible) — used by the /copilot LangChain agent
OPENROUTER_API_KEY=
# Model slug on OpenRouter (override if you prefer another)
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Base URL (rarely needs changing)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Secondary server (SERVER.md): main-backend -> this server (X-API-Key) ---
SERVER_SHARED_SECRET=devsecret

# --- KB adapter (KB-ADAPTER.md): ProfSidekick -> this server (Authorization: Bearer) ---
KB_SERVICE_API_KEY=devsecret
MARKET_COLLECTION_ID=abudhabi-market-v1
# Turn on the heavy LangChain agent for /query (off by default to stay under the 5s timeout)
KB_SMART_PATH=false

# Optional: OpenAI key for RAG embeddings (else a local offline model is used)
OPENAI_API_KEY=
